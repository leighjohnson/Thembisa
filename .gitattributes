# Normalize all text files to LF
* text=auto eol=lf

# C++ source files
*.c     text eol=lf
*.cc    text eol=lf
*.cpp   text eol=lf
*.cxx   text eol=lf
*.h     text eol=lf
*.hh    text eol=lf
*.hpp   text eol=lf
*.hxx   text eol=lf

# CMake, build scripts
CMakeLists.txt text eol=lf
*.cmake        text eol=lf
*.sh           text eol=lf
*.ps1          text eol=lf

# Optional: Windows batch files *must* stay CRLF
*.bat text eol=crlf
